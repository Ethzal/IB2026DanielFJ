<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- CABECERA -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Botón Atrás -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/atras"
            android:textColor="@color/brand_green"
            android:textSize="16sp"
            android:textStyle="bold"
            app:drawableStartCompat="@drawable/ic_arrow_back"
            android:drawablePadding="8dp"
            app:drawableTint="@color/brand_green" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/mis_facturas"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/direccion"
            android:layout_marginTop="8dp"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"/>
    </LinearLayout>

    <!-- TABS (Luz / Gas) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabSelectedTextColor="@color/text_main"
        app:tabTextColor="@color/text_secondary"
        app:tabIndicatorColor="@color/brand_green"
        app:tabTextAppearance="@style/CustomTabTextAppearance"
        app:tabMode="scrollable"
        app:tabGravity="start"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/luz" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/gas" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Línea separadora de los tabs -->
    <View
        android:id="@+id/tabDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"/>

    <!-- VIEW FLIPPER PARA GESTIONAR LA CARGA -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabDivider"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- ESTADO 0: Skeleton Loading -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerViewContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">
                <!-- Esqueleto Tarjeta -->
                <View android:layout_width="match_parent" android:layout_height="180dp" android:background="#E0E0E0" />
                <View android:layout_width="150dp" android:layout_height="24dp" android:layout_marginTop="32dp" android:background="#E0E0E0" />
                <!-- Esqueletos Lista -->
                <View android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="16dp" android:background="#E0E0E0" />
                <View android:layout_width="match_parent" android:layout_height="60dp" android:layout_marginTop="16dp" android:background="#E0E0E0" />
            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- ESTADO 1: Contenido Real -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- TARJETA: ÚLTIMA FACTURA -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:strokeColor="@color/brand_green"
                    app:strokeWidth="1dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    android:layout_marginTop="8dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvLastInvoiceTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ultima_factura"
                            android:textColor="@color/text_main"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <ImageView
                            android:id="@+id/ivIconType"
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:contentDescription="@string/tipo_de_icono"
                            android:src="@drawable/ic_lightbulb"
                            app:tint="@color/brand_green"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <TextView
                            android:id="@+id/tvLastInvoiceType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/factura_luz"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"
                            app:layout_constraintTop_toBottomOf="@id/tvLastInvoiceTitle"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/tvLastInvoiceAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="20,00 €"
                            android:textColor="@color/text_main"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:layout_marginTop="16dp"
                            app:layout_constraintTop_toBottomOf="@id/tvLastInvoiceType"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/tvLastInvoiceDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="01 feb. 2024 - 04 mar. 2024"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"
                            app:layout_constraintTop_toBottomOf="@id/tvLastInvoiceAmount"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <!-- Línea separadora dentro de la tarjeta -->
                        <View
                            android:id="@+id/dividerCard"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider_color"
                            android:layout_marginTop="16dp"
                            app:layout_constraintTop_toBottomOf="@id/tvLastInvoiceDate"/>

                        <TextView
                            android:id="@+id/tvLastInvoiceStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="Pendiente de Pago"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_pendient"
                            android:background="@drawable/bg_pill_pendient"
                            android:layout_marginTop="16dp"
                            app:layout_constraintTop_toBottomOf="@id/dividerCard"
                            app:layout_constraintStart_toStartOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CABECERA HISTÓRICO Y BOTÓN FILTRAR -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp">

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/historico_de_facturas"
                        android:textColor="@color/text_main"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btnFilter"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFilter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filtrar"
                        android:textColor="@color/brand_green"
                        app:icon="@drawable/ic_filter"
                        app:iconTint="@color/brand_green"
                        app:strokeWidth="2dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:textAllCaps="false"
                        app:strokeColor="@color/brand_green"
                        app:cornerRadius="20dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/_2024"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"/>

                <!-- LISTA HISTÓRICO (RecyclerView) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvInvoices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_invoice"
                    tools:itemCount="3"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </ViewFlipper>
</androidx.constraintlayout.widget.ConstraintLayout>