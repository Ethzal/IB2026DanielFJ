<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- CABECERA -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_m"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/atras"
            android:textColor="@color/brand_green"
            style="@style/TextAppearance.App.BodyPrimary"
            app:drawableStartCompat="@drawable/ic_arrow_back"
            android:drawablePadding="@dimen/spacing_s"
            app:drawableTint="@color/brand_green" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/local"
            android:layoutDirection="rtl"
            android:checked="true"
            android:textColor="@color/text_main"
            android:switchPadding="@dimen/spacing_m"
            app:thumbTint="@color/white"
            app:trackTint="@color/gray"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_m"
            android:text="@string/mis_facturas"
            style="@style/TextAppearance.App.TitleMain"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/direccion"
            android:layout_marginTop="@dimen/spacing_s"
            style="@style/TextAppearance.App.TitleSecondary"/>
    </LinearLayout>

    <!-- TABS (Luz / Gas) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabSelectedTextColor="@color/text_main"
        app:tabTextColor="@color/text_secondary"
        app:tabIndicatorColor="@color/brand_green"
        app:tabTextAppearance="@style/CustomTabTextAppearance"
        app:tabMode="scrollable"
        app:tabGravity="start"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/luz" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/gas" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Línea separadora de los tabs -->
    <View
        android:id="@+id/tabDivider"
        style="@style/Widget.App.Divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"/>

    <!-- VIEW FLIPPER PARA GESTIONAR LA CARGA -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabDivider"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- ESTADO 0: Skeleton Loading -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerViewContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="@dimen/spacing_m">
                <View style="@style/Widget.App.ShimmerView" android:layout_width="match_parent" android:layout_height="@dimen/shimmer_card_height" />
                <View style="@style/Widget.App.ShimmerView" android:layout_width="@dimen/shimmer_title_width" android:layout_height="@dimen/spacing_l" android:layout_marginTop="@dimen/spacing_xl" />
                <View style="@style/Widget.App.ShimmerView" android:layout_width="match_parent" android:layout_height="@dimen/shimmer_item_height" android:layout_marginTop="@dimen/spacing_m" />
                <View style="@style/Widget.App.ShimmerView" android:layout_width="match_parent" android:layout_height="@dimen/shimmer_item_height" android:layout_marginTop="@dimen/spacing_m" />
            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- ESTADO 1: Contenido Real -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_m">

                <!-- TARJETA: ÚLTIMA FACTURA -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.App.Card.Invoice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_s">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/spacing_m">

                        <TextView
                            android:id="@+id/tvLastInvoiceTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ultima_factura"
                            style="@style/TextAppearance.App.BodyPrimary"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <ImageView
                            android:id="@+id/ivIconType"
                            android:layout_width="@dimen/icon_size_m"
                            android:layout_height="@dimen/icon_size_m"
                            android:contentDescription="@string/tipo_de_icono"
                            android:src="@drawable/ic_lightbulb"
                            app:tint="@color/brand_green"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                        <TextView
                            android:id="@+id/tvLastInvoiceType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/factura_luz"
                            style="@style/TextAppearance.App.BodySecondary"
                            android:layout_marginTop="@dimen/spacing_xs"
                            app:layout_constraintTop_toBottomOf="@id/tvLastInvoiceTitle"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/tvLastInvoiceAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="20,00 €"
                            style="@style/TextAppearance.App.Amount"
                            android:layout_marginTop="@dimen/spacing_m"
                            app:layout_constraintTop_toBottomOf="@id/tvLastInvoiceType"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <TextView
                            android:id="@+id/tvLastInvoiceDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="01 feb. 2024 - 04 mar. 2024"
                            style="@style/TextAppearance.App.BodySecondary"
                            android:layout_marginTop="@dimen/spacing_xs"
                            app:layout_constraintTop_toBottomOf="@id/tvLastInvoiceAmount"
                            app:layout_constraintStart_toStartOf="parent"/>

                        <!-- Línea separadora dentro de la tarjeta -->
                        <View
                            android:id="@+id/dividerCard"
                            style="@style/Widget.App.Divider"
                            android:layout_marginTop="@dimen/spacing_m"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/tvLastInvoiceDate"/>

                        <TextView
                            android:id="@+id/tvLastInvoiceStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            tools:text="Pendiente de Pago"
                            style="@style/TextAppearance.App.Pill"
                            android:layout_marginTop="@dimen/spacing_m"
                            app:layout_constraintTop_toBottomOf="@id/dividerCard"
                            app:layout_constraintStart_toStartOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CABECERA HISTÓRICO Y BOTÓN FILTRAR -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xl">

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/historico_de_facturas"
                        style="@style/TextAppearance.App.TitleSecondary"
                        android:ellipsize="end"
                        android:maxLines="1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btnFilter"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFilter"
                        style="@style/Widget.App.Button.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/filtrar"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/_2024"
                    style="@style/TextAppearance.App.BodyPrimary"
                    android:layout_marginTop="@dimen/spacing_m"/>

                <!-- LISTA HISTÓRICO (RecyclerView) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvInvoices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_s"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_invoice"
                    tools:itemCount="3"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </ViewFlipper>
</androidx.constraintlayout.widget.ConstraintLayout>