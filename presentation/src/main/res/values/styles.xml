<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CustomTabTextAppearance" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.App.TitleMain" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">@dimen/text_size_xxl</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_main</item>
    </style>

    <style name="TextAppearance.App.TitleSecondary" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_size_xl</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_main</item>
    </style>

    <style name="TextAppearance.App.BodyPrimary" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">@dimen/text_size_l</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_main</item>
    </style>

    <style name="TextAppearance.App.BodySecondary" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">@dimen/text_size_s</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.App.Amount" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textSize">@dimen/text_size_amount</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_main</item>
    </style>

    <style name="TextAppearance.App.Pill" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">@dimen/text_size_xs</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.App.Divider" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/divider_height</item>
        <item name="android:background">@color/divider_color</item>
    </style>

    <style name="Widget.App.Button.Filter" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/brand_green</item>
        <item name="strokeColor">@color/brand_green</item>
        <item name="strokeWidth">@dimen/stroke_width_thick</item>
        <item name="rippleColor">@color/brand_green_light</item>
        <item name="cornerRadius">@dimen/corner_radius_button</item>
        <item name="icon">@drawable/ic_filter</item>
        <item name="iconTint">@color/brand_green</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.App.Card.Invoice" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@android:color/white</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/brand_green</item>
        <item name="strokeWidth">@dimen/stroke_width_default</item>
        <item name="cardCornerRadius">@dimen/corner_radius_default</item>
    </style>

    <style name="Widget.App.ShimmerView" parent="">
        <item name="android:background">@color/divider_color</item>
    </style>
</resources>